        {
          "type": "SYMBOL",
          "name": "tag"
        },
        {
          "type": "SYMBOL",
          "name": "paragraph_style"
        }
      ]
    },
    "heading": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "heading_marker_with_label"
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "SYMBOL",
                "name": "_inline"
              }
            },
            {
              "type": "STRING",
              "value": "}"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "heading_marker"
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "SYMBOL",
                "name": "_inline"
              }
            },
            {
              "type": "STRING",
              "value": "}"
            }
          ]
        }
      ]
    },
    "heading_marker": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "{"
          },
          {
            "type": "PATTERN",
            "value": "[0-9]+"
          }
        ]
      }
    },
    "heading_marker_with_label": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "{"
          },
          {
            "type": "PATTERN",
            "value": "[0-9]+"
          },
          {
            "type": "STRING",
            "value": ":"
          },
          {
            "type": "PATTERN",
            "value": "[^ \\t\\n\\r}]+"
          }
        ]
      }
    },
    "paragraph": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "SYMBOL",
          "name": "_inline"
        }
      }
    },
    "_inline": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "word"
        },
        {
          "type": "SYMBOL",
          "name": "escape_sequence"
        },
        {
          "type": "SYMBOL",
          "name": "code_span"
        },
        {
          "type": "SYMBOL",
          "name": "bold"
        },
        {
          "type": "SYMBOL",
          "name": "italic"
        },
        {
          "type": "SYMBOL",
          "name": "emphasis"
        },
        {
          "type": "SYMBOL",
          "name": "superscript"
        },
        {
          "type": "SYMBOL",
          "name": "subscript"
        },
        {
          "type": "SYMBOL",
          "name": "math_span"
        },
        {
          "type": "SYMBOL",
          "name": "simple_reference"
        },
        {
          "type": "SYMBOL",
          "name": "reference_with_text"
        },
        {
          "type": "SYMBOL",
          "name": "simple_link"
        },
        {
          "type": "SYMBOL",
          "name": "link_with_text"
        },
        {
          "type": "SYMBOL",
          "name": "minus"
        },
        {
          "type": "SYMBOL",
          "name": "plus"
        }
      ]
    },
    "word": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SEQ",
            "members": [
              {
                "type": "PATTERN",
                "value": "[^\\s{}\\[\\]@|\\\\+\\-]"
              },
              {
                "type": "REPEAT",
                "content": {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "PATTERN",
                      "value": "[^\\s{}\\[\\]@|\\\\]"
                    },
                    {
                      "type": "SEQ",
                      "members": [
                        {
                          "type": "STRING",
                          "value": "\\"
                        },
                        {
                          "type": "PATTERN",
                          "value": "[{}\\[\\]@]"
                        }
                      ]
                    },
                    {
                      "type": "PATTERN",
                      "value": "[+\\-@]"
                    }
                  ]
                }
              }
            ]
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "PATTERN",
                "value": "[+\\-]"
              },
              {
                "type": "REPEAT1",
                "content": {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "PATTERN",
                      "value": "[^\\s{}\\[\\]@|\\\\]"
                    },
                    {
                      "type": "SEQ",
                      "members": [
                        {
                          "type": "STRING",
                          "value": "\\"
                        },
                        {
                          "type": "PATTERN",
                          "value": "[{}\\[\\]@]"
                        }
                      ]
                    },
                    {
                      "type": "PATTERN",
                      "value": "[+\\-@]"
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
