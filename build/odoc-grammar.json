{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "odoc",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_block"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          },
          {
            "type": "SYMBOL",
            "name": "_blank_line"
          }
        ]
      }
    },
    "_block": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "heading"
        },
        {
          "type": "SYMBOL",
          "name": "paragraph"
        },
        {
          "type": "SYMBOL",
          "name": "code_block"
        },
        {
          "type": "SYMBOL",
          "name": "code_block_with_lang"
        },
        {
          "type": "SYMBOL",
          "name": "verbatim_block"
        },
        {
          "type": "SYMBOL",
          "name": "math_block"
        },
        {
          "type": "SYMBOL",
          "name": "unordered_list"
        },
        {
          "type": "SYMBOL",
          "name": "ordered_list"
        },
        {
          "type": "SYMBOL",
          "name": "light_list"
        },
        {
          "type": "SYMBOL",
          "name": "table_heavy"
